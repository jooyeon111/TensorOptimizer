
BASE_CONFIG_PATH := input/simulation/configs/designExplorer
LAYER_RESNET50_CONV2_1x1 := input/simulation/layer/resnet/stage4_block1_conv3_1x1.cfg
TEST_OPTION_1024 = $(BASE_CONFIG_PATH)/ddr4_total_multiplier_1024.cfg

TEST_OPTION_DRAM_REF := input/simulation/hardware_reference/DRAMsim3/ddr4_dram.cfg
TEST_OPTION_SRAM_REF := input/simulation/hardware_reference/nvsim/sram.cfg
TEST_OPTION_RTL_RESULT_REF := input/simulation/hardware_reference/design_compiler/array.cfg

.PHONY: run
run:
	sbt "runMain simulation.DesignExplorerMain ${LAYER_RESNET50_CONV2_1x1} ${TEST_OPTION_1024} ${TEST_OPTION_DRAM_REF} ${TEST_OPTION_SRAM_REF} ${TEST_OPTION_RTL_RESULT_REF}"


