#                                                     Analyzer                                                        #
########################################################################################################################
BASE_CONFIG_PATH := input/simulation/configs/analyzer

# Layer configurations
CONV1 := input/simulation/layer/resnet/conv1.cfg
STAGE1_BLOCK1_CONV1 := input/simulation/layer/resnet/stage1_block1_conv1_1x1.cfg
