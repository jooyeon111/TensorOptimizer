FC := input/simulation/layer/resnet/fc.cfg

# Test options
TEST_OPTION_OS_SD_32 = $(BASE_CONFIG_PATH)/oneLayer/os_{32x32}x{1x1}x1_sd_32.cfg
TEST_OPTION_OS_SD_256 = $(BASE_CONFIG_PATH)/oneLayer/os_{32x32}x{1x1}x1_sd_256.cfg
TEST_OPTION_OS_SD_1024 = $(BASE_CONFIG_PATH)/oneLayer/os_{32x32}x{1x1}x1_sd_1024.cfg
TEST_OPTION_WS_SD_32 = $(BASE_CONFIG_PATH)/oneLayer/ws_{32x32}x{1x1}x1_sd_32.cfg
TEST_OPTION_WS_SD_256 = $(BASE_CONFIG_PATH)/oneLayer/ws_{32x32}x{1x1}x1_sd_256.cfg

.PHONY: all
all: conv1 stage1 stage2 stage3 stage4 fc

.PHONY: conv1
conv1:
	#Square
	sbt "runMain simulation.AnalyzerMain ${CONV1} ${TEST_OPTION_OS_SD_32}"
	sbt "runMain simulation.AnalyzerMain ${CONV1} ${TEST_OPTION_WS_SD_32}"
	#Large
	sbt "runMain simulation.AnalyzerMain ${CONV1} ${TEST_OPTION_OS_SD_256}"
	sbt "runMain simulation.AnalyzerMain ${CONV1} ${TEST_OPTION_WS_SD_256}"

