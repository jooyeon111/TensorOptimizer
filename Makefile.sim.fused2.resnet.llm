# Common paths
INPUT_SIM := input/simulation
CONFIG_DIR := $(INPUT_SIM)/configs/analyzer/oneLayer
TILING_DIR := $(INPUT_SIM)/configs/analyzer/tiling
HARDWARE_REF := $(INPUT_SIM)/hardware_reference
LAYER_DIR := $(INPUT_SIM)/layer

# Test options
TEST_OPTION_MULT := $(CONFIG_DIR)/fused2_ws_16x16x2x4x8.cfg
TEST_OPTION_OFF_CHIP_MEM_REF := $(HARDWARE_REF)/DRAMsim3/hbm2.cfg
TEST_OPTION_SRAM_REF := $(HARDWARE_REF)/nvsim/sram.cfg
TEST_OPTION_DESIGN_COMPILER = $(HARDWARE_REF)/design_compiler/fused2.cfg

TEST_OPTION_TILING_1 := $(TILING_DIR)/tiling1.cfg
TEST_OPTION_TILING_49 := $(TILING_DIR)/tiling49.cfg
TEST_OPTION_TILING_128 := $(TILING_DIR)/tiling128.cfg
TEST_OPTION_TILING_147 := $(TILING_DIR)/tiling147.cfg
TEST_OPTION_TILING_196 := $(TILING_DIR)/tiling196.cfg
TEST_OPTION_TILING_197 := $(TILING_DIR)/tiling197.cfg
TEST_OPTION_TILING_256 := $(TILING_DIR)/tiling256.cfg
TEST_OPTION_TILING_392 := $(TILING_DIR)/tiling392.cfg

COMMON_ARGS_TILING_1 := $(TEST_OPTION_MULT) $(TEST_OPTION_TILING_1) $(TEST_OPTION_OFF_CHIP_MEM_REF) $(TEST_OPTION_SRAM_REF) $(TEST_OPTION_DESIGN_COMPILER)
COMMON_ARGS_TILING_49 := $(TEST_OPTION_MULT) $(TEST_OPTION_TILING_49) $(TEST_OPTION_OFF_CHIP_MEM_REF) $(TEST_OPTION_SRAM_REF) $(TEST_OPTION_DESIGN_COMPILER)
COMMON_ARGS_TILING_128 := $(TEST_OPTION_MULT) $(TEST_OPTION_TILING_128) $(TEST_OPTION_OFF_CHIP_MEM_REF) $(TEST_OPTION_SRAM_REF) $(TEST_OPTION_DESIGN_COMPILER)
COMMON_ARGS_TILING_147 := $(TEST_OPTION_MULT) $(TEST_OPTION_TILING_147) $(TEST_OPTION_OFF_CHIP_MEM_REF) $(TEST_OPTION_SRAM_REF) $(TEST_OPTION_DESIGN_COMPILER)
COMMON_ARGS_TILING_196 := $(TEST_OPTION_MULT) $(TEST_OPTION_TILING_196) $(TEST_OPTION_OFF_CHIP_MEM_REF) $(TEST_OPTION_SRAM_REF) $(TEST_OPTION_DESIGN_COMPILER)
COMMON_ARGS_TILING_197 := $(TEST_OPTION_MULT) $(TEST_OPTION_TILING_197) $(TEST_OPTION_OFF_CHIP_MEM_REF) $(TEST_OPTION_SRAM_REF) $(TEST_OPTION_DESIGN_COMPILER)
COMMON_ARGS_TILING_256 := $(TEST_OPTION_MULT) $(TEST_OPTION_TILING_256) $(TEST_OPTION_OFF_CHIP_MEM_REF) $(TEST_OPTION_SRAM_REF) $(TEST_OPTION_DESIGN_COMPILER)
COMMON_ARGS_TILING_392 := $(TEST_OPTION_MULT) $(TEST_OPTION_TILING_392) $(TEST_OPTION_OFF_CHIP_MEM_REF) $(TEST_OPTION_SRAM_REF) $(TEST_OPTION_DESIGN_COMPILER)

# bert
BERT_BASE_PATH := $(LAYER_DIR)/bert/base
BERT_BASE_QKV := $(BERT_BASE_PATH)/projection.cfg
BERT_BASE_QKT := $(BERT_BASE_PATH)/qkt.cfg
BERT_BASE_QKTV := $(BERT_BASE_PATH)/qktv.cfg
BERT_BASE_FINAL := $(BERT_BASE_PATH)/representation_projection.cfg

# bloom
BLOOM_1B_PATH := $(LAYER_DIR)/bloom/1b
BLOOM_1B_QKV := $(BLOOM_1B_PATH)/projection.cfg
BLOOM_1B_QKT := $(BLOOM_1B_PATH)/qkt.cfg
BLOOM_1B_QKTV := $(BLOOM_1B_PATH)/qktv.cfg
BLOOM_1B_FINAL := $(BLOOM_1B_PATH)/representation_projection.cfg

# falcon
FALCON_1B_PATH := $(LAYER_DIR)/falcon/1b
FALCON_1B_QKV := $(FALCON_1B_PATH)/projection.cfg
FALCON_1B_QKT := $(FALCON_1B_PATH)/qkt.cfg
FALCON_1B_QKTV := $(FALCON_1B_PATH)/qktv.cfg
FALCON_1B_FINAL := $(FALCON_1B_PATH)/representation_projection.cfg

# llama
LLAMA_7B_PATH := $(LAYER_DIR)/llama/7b
LLAMA_7B_QKV := $(LLAMA_7B_PATH)/projection.cfg
LLAMA_7B_QKT := $(LLAMA_7B_PATH)/qkt.cfg
LLAMA_7B_QKTV := $(LLAMA_7B_PATH)/qktv.cfg
LLAMA_7B_FINAL := $(LLAMA_7B_PATH)/representation_projection.cfg

# mistral
MISTRAL_7B_PATH := $(LAYER_DIR)/mistral/7b
MISTRAL_7B_QKV := $(MISTRAL_7B_PATH)/projection.cfg
MISTRAL_7B_QKT := $(MISTRAL_7B_PATH)/qkt.cfg
MISTRAL_7B_QKTV := $(MISTRAL_7B_PATH)/qktv.cfg
MISTRAL_7B_FINAL := $(MISTRAL_7B_PATH)/representation_projection.cfg

# phi
PHI_2_PATH := $(LAYER_DIR)/phi/2
PHI_2_QKV := $(PHI_2_PATH)/projection.cfg
PHI_2_QKT := $(PHI_2_PATH)/qkt.cfg
PHI_2_QKTV := $(PHI_2_PATH)/qktv.cfg
PHI_2_FINAL := $(PHI_2_PATH)/representation_projection.cfg

#resnet50
RESNET_50_PATH := $(LAYER_DIR)/resnet/50

RESNET_50_CONV1 := $(RESNET_50_PATH)/conv1.cfg
#STAGE1
STAGE1_BLOCK1_CONV1 := $(RESNET_50_PATH)/stage1_block1_conv1.cfg
STAGE1_BLOCK1_CONV2 := $(RESNET_50_PATH)/stage1_block1_conv2.cfg
STAGE1_BLOCK1_CONV3 := $(RESNET_50_PATH)/stage1_block1_conv3.cfg
STAGE1_SHORTCUT := $(RESNET_50_PATH)/stage1_block1_shortcut.cfg
STAGE1_BLOCK2_CONV1 := $(RESNET_50_PATH)/stage1_block2_conv1.cfg
STAGE1_BLOCK2_CONV2 := $(RESNET_50_PATH)/stage1_block2_conv2.cfg
STAGE1_BLOCK2_CONV3 := $(RESNET_50_PATH)/stage1_block2_conv3.cfg
STAGE1_BLOCK3_CONV1 := $(RESNET_50_PATH)/stage1_block3_conv1.cfg
STAGE1_BLOCK3_CONV2 := $(RESNET_50_PATH)/stage1_block3_conv2.cfg
STAGE1_BLOCK3_CONV3 := $(RESNET_50_PATH)/stage1_block3_conv3.cfg

#STAGE2
STAGE2_BLOCK1_CONV1 := $(RESNET_50_PATH)/stage2_block1_conv1.cfg
STAGE2_BLOCK1_CONV2 := $(RESNET_50_PATH)/stage2_block1_conv2.cfg
STAGE2_BLOCK1_CONV3 := $(RESNET_50_PATH)/stage2_block1_conv3.cfg
STAGE2_SHORTCUT := $(RESNET_50_PATH)/stage2_block1_shortcut.cfg
STAGE2_BLOCK2_CONV1 := $(RESNET_50_PATH)/stage2_block2_conv1.cfg
STAGE2_BLOCK2_CONV2 := $(RESNET_50_PATH)/stage2_block2_conv2.cfg
STAGE2_BLOCK2_CONV3 := $(RESNET_50_PATH)/stage2_block2_conv3.cfg
STAGE2_BLOCK3_CONV1 := $(RESNET_50_PATH)/stage2_block3_conv1.cfg
STAGE2_BLOCK3_CONV2 := $(RESNET_50_PATH)/stage2_block3_conv2.cfg
STAGE2_BLOCK3_CONV3 := $(RESNET_50_PATH)/stage2_block3_conv3.cfg
STAGE2_BLOCK4_CONV1 := $(RESNET_50_PATH)/stage2_block4_conv1.cfg
STAGE2_BLOCK4_CONV2 := $(RESNET_50_PATH)/stage2_block4_conv2.cfg
STAGE2_BLOCK4_CONV3 := $(RESNET_50_PATH)/stage2_block4_conv3.cfg

#STAGE3
STAGE3_BLOCK1_CONV1 := $(RESNET_50_PATH)/stage3_block1_conv1.cfg
STAGE3_BLOCK1_CONV2 := $(RESNET_50_PATH)/stage3_block1_conv2.cfg
STAGE3_BLOCK1_CONV3 := $(RESNET_50_PATH)/stage3_block1_conv3.cfg
STAGE3_SHORTCUT := $(RESNET_50_PATH)/stage3_block1_shortcut.cfg
STAGE3_BLOCK2_CONV1 := $(RESNET_50_PATH)/stage3_block2_conv1.cfg
STAGE3_BLOCK2_CONV2 := $(RESNET_50_PATH)/stage3_block2_conv2.cfg
STAGE3_BLOCK2_CONV3 := $(RESNET_50_PATH)/stage3_block2_conv3.cfg
STAGE3_BLOCK3_CONV1 := $(RESNET_50_PATH)/stage3_block3_conv1.cfg
STAGE3_BLOCK3_CONV2 := $(RESNET_50_PATH)/stage3_block3_conv2.cfg
STAGE3_BLOCK3_CONV3 := $(RESNET_50_PATH)/stage3_block3_conv3.cfg
STAGE3_BLOCK4_CONV1 := $(RESNET_50_PATH)/stage3_block4_conv1.cfg
STAGE3_BLOCK4_CONV2 := $(RESNET_50_PATH)/stage3_block4_conv2.cfg
STAGE3_BLOCK4_CONV3 := $(RESNET_50_PATH)/stage3_block4_conv3.cfg
STAGE3_BLOCK5_CONV1 := $(RESNET_50_PATH)/stage3_block5_conv1.cfg
STAGE3_BLOCK5_CONV2 := $(RESNET_50_PATH)/stage3_block5_conv2.cfg
STAGE3_BLOCK5_CONV3 := $(RESNET_50_PATH)/stage3_block5_conv3.cfg
STAGE3_BLOCK6_CONV1 := $(RESNET_50_PATH)/stage3_block6_conv1.cfg
STAGE3_BLOCK6_CONV2 := $(RESNET_50_PATH)/stage3_block6_conv2.cfg
STAGE3_BLOCK6_CONV3 := $(RESNET_50_PATH)/stage3_block6_conv3.cfg

#STAGE4
STAGE4_BLOCK1_CONV1 := $(RESNET_50_PATH)/stage4_block1_conv1.cfg
STAGE4_BLOCK1_CONV2 := $(RESNET_50_PATH)/stage4_block1_conv2.cfg
STAGE4_BLOCK1_CONV3 := $(RESNET_50_PATH)/stage4_block1_conv3.cfg
STAGE4_SHORTCUT := $(RESNET_50_PATH)/stage4_block1_shortcut.cfg
STAGE4_BLOCK2_CONV1 := $(RESNET_50_PATH)/stage4_block2_conv1.cfg
STAGE4_BLOCK2_CONV2 := $(RESNET_50_PATH)/stage4_block2_conv2.cfg
STAGE4_BLOCK2_CONV3 := $(RESNET_50_PATH)/stage4_block2_conv3.cfg
STAGE4_BLOCK3_CONV1 := $(RESNET_50_PATH)/stage4_block3_conv1.cfg
STAGE4_BLOCK3_CONV2 := $(RESNET_50_PATH)/stage4_block3_conv2.cfg
STAGE4_BLOCK3_CONV3 := $(RESNET_50_PATH)/stage4_block3_conv3.cfg

#FC
RESNET_50_FC := $(RESNET_50_PATH)/fc.cfg

# Define targets for specific layers
.PHONY: all bert_base bloom_1b falcon_1b llama_7b mistral_7b phi_2 resnet_50

# Default target runs all configurations for the specified model/variant
all: bert_base bloom_1b falcon_1b llama_7b mistral_7b phi_2 resnet_50

# Target to run a specific layer model
bert_base:
	sbt "runMain simulation.AnalyzerMain $(BERT_BASE_QKV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(BERT_BASE_QKT) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(BERT_BASE_QKTV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(BERT_BASE_FINAL) $(COMMON_ARGS_TILING_256)"

bloom_1b:
	sbt "runMain simulation.AnalyzerMain $(BLOOM_1B_QKV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(BLOOM_1B_QKT) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(BLOOM_1B_QKTV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(BLOOM_1B_FINAL) $(COMMON_ARGS_TILING_256)"

falcon_1b:
	sbt "runMain simulation.AnalyzerMain $(FALCON_1B_QKV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(FALCON_1B_QKT) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(FALCON_1B_QKTV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(FALCON_1B_FINAL) $(COMMON_ARGS_TILING_256)"

llama_7b:
	sbt "runMain simulation.AnalyzerMain $(LLAMA_7B_QKV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(LLAMA_7B_QKT) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(LLAMA_7B_QKTV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(LLAMA_7B_FINAL) $(COMMON_ARGS_TILING_256)"

mistral_7b:
	sbt "runMain simulation.AnalyzerMain $(MISTRAL_7B_QKV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(MISTRAL_7B_QKT) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(MISTRAL_7B_QKTV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(MISTRAL_7B_FINAL) $(COMMON_ARGS_TILING_256)"

phi_2:
	sbt "runMain simulation.AnalyzerMain $(PHI_2_QKV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(PHI_2_QKT) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(PHI_2_QKTV) $(COMMON_ARGS_TILING_256)"
	sbt "runMain simulation.AnalyzerMain $(PHI_2_FINAL) $(COMMON_ARGS_TILING_256)"

resnet_50:
	sbt "runMain simulation.AnalyzerMain $(RESNET_50_CONV1) $(COMMON_ARGS_TILING_196)"

	sbt "runMain simulation.AnalyzerMain $(STAGE1_BLOCK1_CONV1) $(COMMON_ARGS_TILING_128)"
	sbt "runMain simulation.AnalyzerMain $(STAGE1_BLOCK1_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE1_BLOCK1_CONV3) $(COMMON_ARGS_TILING_128)"
	sbt "runMain simulation.AnalyzerMain $(STAGE1_SHORTCUT) $(COMMON_ARGS_TILING_128)"
	sbt "runMain simulation.AnalyzerMain $(STAGE1_BLOCK2_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE1_BLOCK2_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE1_BLOCK2_CONV3) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE1_BLOCK3_CONV1) $(COMMON_ARGS_TILING_128)"
	sbt "runMain simulation.AnalyzerMain $(STAGE1_BLOCK3_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE1_BLOCK3_CONV3) $(COMMON_ARGS_TILING_128)"

	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK1_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK1_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK1_CONV3) $(COMMON_ARGS_TILING_128)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_SHORTCUT) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK2_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK2_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK2_CONV3) $(COMMON_ARGS_TILING_128)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK3_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK3_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK3_CONV3) $(COMMON_ARGS_TILING_128)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK4_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK4_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE2_BLOCK4_CONV3) $(COMMON_ARGS_TILING_128)"

	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK1_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK1_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK1_CONV3) $(COMMON_ARGS_TILING_128)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_SHORTCUT) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK2_CONV1) $(COMMON_ARGS_TILING_128)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK2_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK2_CONV3) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK3_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK3_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK3_CONV3) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK4_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK4_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK4_CONV3) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK5_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK5_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK5_CONV3) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK6_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK6_CONV2) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE3_BLOCK6_CONV3) $(COMMON_ARGS_TILING_196)"

	sbt "runMain simulation.AnalyzerMain $(STAGE4_BLOCK1_CONV1) $(COMMON_ARGS_TILING_196)"
	sbt "runMain simulation.AnalyzerMain $(STAGE4_BLOCK1_CONV2) $(COMMON_ARGS_TILING_49)"
	sbt "runMain simulation.AnalyzerMain $(STAGE4_BLOCK1_CONV3) $(COMMON_ARGS_TILING_49)"
	sbt "runMain simulation.AnalyzerMain $(STAGE4_SHORTCUT) $(COMMON_ARGS_TILING_49)"
	sbt "runMain simulation.AnalyzerMain $(STAGE4_BLOCK2_CONV1) $(COMMON_ARGS_TILING_49)"
	sbt "runMain simulation.AnalyzerMain $(STAGE4_BLOCK2_CONV2) $(COMMON_ARGS_TILING_49)"
	sbt "runMain simulation.AnalyzerMain $(STAGE4_BLOCK2_CONV3) $(COMMON_ARGS_TILING_49)"
	sbt "runMain simulation.AnalyzerMain $(STAGE4_BLOCK3_CONV1) $(COMMON_ARGS_TILING_49)"
	sbt "runMain simulation.AnalyzerMain $(STAGE4_BLOCK3_CONV2) $(COMMON_ARGS_TILING_49)"
	sbt "runMain simulation.AnalyzerMain $(STAGE4_BLOCK3_CONV3) $(COMMON_ARGS_TILING_49)"

	sbt "runMain simulation.AnalyzerMain $(RESNET_50_FC) $(COMMON_ARGS_TILING_1)"

