	sbt "runMain simulation.SystemArchitectureOptimizer $(RESNET) $(COMMON_ARGS_80_100_100)"
	sbt "runMain simulation.SystemArchitectureOptimizer $(BERT) $(COMMON_ARGS_80_100_100)"

