	sbt "runMain simulation.SystemArchitectureOptimizer $(MOBILE) $(COMMON_ARGS_70_100_100)"
	sbt "runMain simulation.SystemArchitectureOptimizer $(RESNET) $(COMMON_ARGS_70_100_100)"
