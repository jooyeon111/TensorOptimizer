# Layer info
LAYER := input/simulation/layer/swin/swin_b_stage4_final_linear_projection.cfg
TEST_LAYER := input/simulation/layer/etc/middle_k.cfg

TEST_OPTION_SRAM_REF := input/simulation/hardware_reference/nvsim/sram.cfg
