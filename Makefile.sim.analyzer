BASE_CONFIG_PATH := input/simulation/configs/analyzer

TEST_16 = $(BASE_CONFIG_PATH)/oneLayer/is_{4x4}x{1x1}x1_sd_16.cfg
TEST_32 = $(BASE_CONFIG_PATH)/oneLayer/is_{4x4}x{1x1}x1_sd_32.cfg
TEST_64 = $(BASE_CONFIG_PATH)/oneLayer/is_{4x4}x{1x1}x1_sd_64.cfg

TEST_OPTION_IS_SD_2 = $(BASE_CONFIG_PATH)/oneLayer/is_{4x4}x{1x1}x1_sd_2.cfg
