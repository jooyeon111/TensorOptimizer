.PHONY: test
test:
	sbt "runMain simulation.AnalyzerMain ${TEST_LAYER} ${TEST_OPTION_IS_SD_2} ${TEST_OPTION_SRAM_REF} ${TEST_OPTION_DRAM_REF} ${TEST_OPTION_RTL_RESULT_REF}"
	sbt "runMain simulation.AnalyzerMain ${TEST_LAYER} ${TEST_OPTION_IS_SD_4} ${TEST_OPTION_SRAM_REF} ${TEST_OPTION_DRAM_REF} ${TEST_OPTION_RTL_RESULT_REF}"
	sbt "runMain simulation.AnalyzerMain ${TEST_LAYER} ${TEST_OPTION_IS_SD_8} ${TEST_OPTION_SRAM_REF} ${TEST_OPTION_DRAM_REF} ${TEST_OPTION_RTL_RESULT_REF}"

